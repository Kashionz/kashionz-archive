const defaultSkillMeta: SkillMeta = {
  description: 'Skill',
  href: '#',
  icon: 'key'
}

function skillToTool(skill: string): ToolItem {
  const meta = skillMeta[skill] ?? defaultSkillMeta
  return {
    name: meta.displayName ?? skill,
    description: meta.description,
    href: meta.href,
    icon: skillIcons[meta.icon]
  }
}

function uniqueByName<T extends { name: string }>(items: T[]): T[] {
  const seen = new Set<string>()
  return items.filter((item) => {
    if (seen.has(item.name))
      return false
    seen.add(item.name)
    return true
  })
}

const movedSkillGroupTitles = new Set(['IDE', 'AI Assistants', 'Operating Systems', 'Design'])
const skillGroupsMap: Record<string, string[]> = Object.fromEntries(
  homeSkillGroups.map((group) => [group.title, group.skills])
)

const aboutSkillSections = homeSkillGroups.map((group) => ({
  title: group.title,
  tools: group.skills.map((skill) => skillToTool(skill))
}))

const filteredAboutSkillSections = aboutSkillSections.filter(
  (group) => !movedSkillGroupTitles.has(group.title)
)

const movedDesignTools = uniqueByName(
  (skillGroupsMap.Design ?? []).map((skill) => skillToTool(skill)).filter((tool) => tool.name !== 'Photoshop')
)

const developmentTools = uniqueByName([
  ...(skillGroupsMap.IDE ?? []).map((skill) => skillToTool(skill)),
  ...(skillGroupsMap['AI Assistants'] ?? []).map((skill) => skillToTool(skill))
])

const environmentTools = uniqueByName([
  ...(skillGroupsMap['Operating Systems'] ?? []).map((skill) => skillToTool(skill)),
