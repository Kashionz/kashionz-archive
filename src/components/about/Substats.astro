---
import { type iconsType, socialLinks } from 'astro-pure/types'
import { Icon } from 'astro-pure/user'

interface SubstatsItem {
  platform: string
  icon: (typeof socialLinks)[number]
  color?: string
  link?: string
  text?: string
  api?: string
  count?: number | string
}

type Props = {
  stats: SubstatsItem[]
}

const { stats } = Astro.props as Props

function sleep(ms: number) {
  return new Promise((resolve) => setTimeout(resolve, ms))
}

async function fetchJsonWithRetry(url: string, init?: RequestInit, retries = 2) {
  let lastError: unknown
  for (let attempt = 0; attempt <= retries; attempt += 1) {
    const response = await fetch(url, init)
    if (response.ok) return response.json()

    if (response.status === 429 && attempt < retries) {
      await sleep(400 * (attempt + 1))
      continue
    }

    lastError = new Error(`Request failed (${response.status})`)
    break
  }
  throw lastError instanceof Error ? lastError : new Error('Request failed')
}

async function fetchInstagramFollowers(username: string) {
  const encodedUsername = encodeURIComponent(username)
  const headers = {
    'x-ig-app-id': '936619743392459',
    'user-agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)',
    'accept-language': 'en-US,en;q=0.9'
  }

  const endpoints = [
    `https://i.instagram.com/api/v1/users/web_profile_info/?username=${encodedUsername}`,
    `https://www.instagram.com/api/v1/users/web_profile_info/?username=${encodedUsername}`
  ]

  for (const endpoint of endpoints) {
    try {
      const data = await fetchJsonWithRetry(endpoint, { headers }, 2)
      const count = data?.data?.user?.edge_followed_by?.count
      if (typeof count === 'number') return count
    } catch {
      continue
    }
  }

  return null
}

async function fetchCount(item: SubstatsItem) {
  if (!item.api) return
  try {
    const response = await fetch(`https://api.swo.moe/stats/${item.api}`)
    if (!response.ok) {
      throw new Error(`Substats API status ${response.status}`)
    }
    const data = await response.json()
    if (data.failed) {
      if (item.api.startsWith('instagram/')) {
        const username = item.api.replace('instagram/', '').trim()
        if (username) {
          const count = await fetchInstagramFollowers(username)
          item.count = count ?? '--'
          return
        }
      }
      throw new Error(data.message)
    } else {
      item.count = data.count
    }
  } catch (error) {
    console.error(`Error in Substats fetching: ${error}`)
  }
}

await Promise.all(stats.map(fetchCount))
---

<div class='grid grid-cols-1 gap-3 rounded-xl border p-2 sm:grid-cols-2 sm:p-3'>
  {
    stats.map(({ link, platform, icon, color, count, text }) => (
      <a
        class='group text-muted-foreground no-underline'
        href={link}
        target='_blank'
        rel='noopener noreferrer'
      >
        <div class='flex items-center gap-3 rounded-lg border border-transparent px-3 py-2 transition-all hover:border-border hover:bg-muted'>
          {icon && <Icon name={icon as iconsType} color={color} />}
          <div class='flex-1 text-foreground transition-colors group-hover:text-primary'>
            {platform}
          </div>
          {count !== undefined && count !== null ? (
            <div class='flex items-center gap-1.5'>
              <samp>{count}</samp>
              {text && <span class='text-sm font-normal'>{text}</span>}
            </div>
          ) : null}
        </div>
      </a>
    ))
  }
</div>
<div class='mt-2 text-right text-sm'>
  Display real-time; powered by <a
    class='text-muted-foreground'
    href='http://github.com/spencerwooo/substats'
    target='_blank'
    rel='noopener noreferrer'>Substats</a
  >
</div>
